# YARP gateway URL (Auth Service)
# For emulator/simulator: use http://localhost:5051
# For physical device: use your machine's local IP (e.g., http://192.168.1.100:5051)
# Find your IP: Windows: ipconfig | macOS/Linux: ifconfig or ip addr
EXPO_PUBLIC_API_URL=http://localhost:5051

# Dev mode: append userId as query param (bypasses gateway auth)
# Keep false for production and release builds
EXPO_PUBLIC_DEV_MODE=false
