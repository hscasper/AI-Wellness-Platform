{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_APP_LINK_HOST": "sakina.example.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://staging-api.sakina.app",
        "EXPO_PUBLIC_APP_LINK_HOST": "staging.sakina.example.com",
        "EXPO_PUBLIC_DEV_MODE": "false"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "demo": {
      "distribution": "internal",
      "channel": "demo",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://REPLACE_WITH_PROD_DOMAIN",
        "EXPO_PUBLIC_APP_LINK_HOST": "REPLACE_WITH_PROD_DOMAIN",
        "EXPO_PUBLIC_DEV_MODE": "false"
      },
      "ios": {
        "resourceClass": "m-medium",
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.sakina.app",
        "EXPO_PUBLIC_APP_LINK_HOST": "sakina.example.com",
        "EXPO_PUBLIC_DEV_MODE": "false"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "REPLACE_WITH_APPLE_APP_ID",
        "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  },
  "update": {
    "production": {
      "channel": "production"
    },
    "preview": {
      "channel": "preview"
    }
  }
}
