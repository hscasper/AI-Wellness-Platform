# ==============================================================================
# AI Wellness Platform - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in actual values before running docker-compose.
#
# SECURITY NOTE: Two credentials were previously committed and remain visible
# in git history (decision: rotate, do not rewrite — see
# security/SEC-ADV-03-git-history.md). Rotation is tracked in the checklist at
# security/secret-rotation.md; the old values MUST be treated as public:
#   - COMMUNITY_DB_PASSWORD (was: postgres)
#   - OPENAI_BASE_URL (was: a RunPod proxy URL)
#
# NEVER commit .env to version control - it contains secrets!
# ==============================================================================

# --- Database Passwords ---
AUTH_DB_PASSWORD=<generate-strong-password>
CHAT_DB_USER=postgres
CHAT_DB_PASSWORD=<generate-strong-password>
NOTIFICATION_DB_PASSWORD=<generate-strong-password>
JOURNAL_DB_PASSWORD=<generate-strong-password>
COMMUNITY_DB_PASSWORD=<rotate-this-was-postgres>

# --- JWT Signing Key (min 32 characters) ---
JWT_KEY=<generate-256-bit-secret>

# --- Redis ---
REDIS_PASSWORD=<generate-strong-password>

# --- Internal API Keys (service-to-service authentication) ---
NOTIFICATION_INTERNAL_API_KEY=<generate-random-secret>
JOURNAL_INTERNAL_API_KEY=<generate-random-secret>
COMMUNITY_INTERNAL_API_KEY=<generate-random-secret>
CHAT_INTERNAL_API_KEY=<generate-random-secret>
AI_INTERNAL_API_KEY=<generate-random-secret>

# --- OpenAI / LLM Provider ---
# OPENAI_BASE_URL previously contained a hardcoded RunPod proxy URL in git history.
# Use the default OpenAI endpoint or your own provider URL. Do NOT reuse the old RunPod URL.
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_BASE_URL=https://api.openai.com/v1/
OPENAI_MODEL=gpt-4

# --- Notification Service (SendGrid) ---
SENDGRID_API_KEY=<sendgrid-api-key>
SENDGRID_FROM_EMAIL=<sender-email-address>
SENDGRID_FROM_NAME=AI Wellness

# --- CORS (optional, for production frontend origin) ---
CORS_ORIGIN_0=http://localhost:8081

# --- Firebase (optional - leave empty to use Expo Push only) ---
# Firebase__ServiceAccountPath=/path/to/service-account.json

# --- Observability (Sentry + structured logging) ---
# Create projects at https://sentry.io and paste the DSNs below. Leaving them
# blank disables Sentry entirely (services/app fall back to stdout logging only).
SENTRY_DSN_AUTH=
SENTRY_DSN_CHAT=
SENTRY_DSN_COMMUNITY=
SENTRY_DSN_JOURNAL=
SENTRY_DSN_NOTIFICATION=
SENTRY_DSN_AI_WRAPPER=
# Applies to every .NET service: fraction of requests sampled for perf tracing (0.0-1.0).
SENTRY_TRACES_SAMPLE_RATE=0.1
# Frontend Sentry DSN is read from Expo public env (EXPO_PUBLIC_SENTRY_DSN).
