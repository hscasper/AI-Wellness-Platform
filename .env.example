# =============================================================================
# Docker Compose Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control - it contains secrets!
# =============================================================================

# --- Database Passwords ---
AUTH_DB_PASSWORD=your-auth-db-password-here
NOTIFICATION_DB_PASSWORD=your-notification-db-password-here
CHAT_DB_USER=postgres
CHAT_DB_PASSWORD=your-chat-db-password-here
REDIS_PASSWORD=your-redis-password-here
JOURNAL_DB_PASSWORD=your-journal-db-password-here

# --- JWT Signing Key (min 32 characters) ---
JWT_KEY=your-jwt-key-here-min-32-characters

# --- Internal API keys (shared between services) ---
NOTIFICATION_INTERNAL_API_KEY=your-notification-internal-key-here
JOURNAL_INTERNAL_API_KEY=your-journal-internal-key-here
AI_INTERNAL_API_KEY=your-ai-wrapper-internal-key-here

# --- AI Wrapper (OpenAI or compatible API) ---
# Get your key from https://platform.openai.com/api-keys
OPENAI_BASE_URL=https://api.openai.com/v1/
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=wellness-chat:latest

# --- SendGrid (email delivery for notifications) ---
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=AI Wellness

# --- CORS (optional, for production frontend origin) ---
# CORS_ORIGIN_0=https://your-frontend-domain.com
