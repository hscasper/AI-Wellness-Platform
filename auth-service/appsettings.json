{
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=authdb;Username=postgres;Password=;Include Error Detail=true"
  },
  "Jwt": {
    "Key": "",
    "Issuer": "AIWellness",
    "Audience": "AIWellnessUsers",
    "ExpiryInMinutes": 60
  },
  "PasswordPolicy": {
    "MinLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSpecialChar": true
  },
  "RateLimiting": {
    "MaxRequestsPerMinute": 100,
    "MaxLoginAttemptsPerMinute": 5
  },
  "AccountLockout": {
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15
  },
  "NotificationService": {
    "BaseUrl": "http://localhost:5085",
    "SendCodeEndpoint": "/api/notifications/send-code",
    "ApiKey": "",
    "DeliveryChannel": "auto"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:8081", "http://localhost:19006"]
  },
  "ReverseProxy": {
    "Routes": {
      "chat-route": {
        "ClusterId": "chat-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/chat/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/notifications/{**catch-all}" }
        ]
      },
      "journal-route": {
        "ClusterId": "journal-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/journal/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/journal/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "chat-cluster": {
        "Destinations": {
          "chat-service": {
            "Address": "http://chat-service:8080/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-service": {
            "Address": "http://notification-service:8080/"
          }
        }
      },
      "journal-cluster": {
        "Destinations": {
          "journal-service": {
            "Address": "http://journal-service:8080/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AIWellness.Auth": "Information",
      "Yarp": "Warning"
    },
    "Console": {
      "LogLevel": {
        "Default": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
