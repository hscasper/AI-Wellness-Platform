firebase-service-account.json
*.pem
*.key
*.p12
*.pfx

# ASP.NET Data Protection key rings (per-service dev fallback).
# In production keys live in Redis; locally they land in these folders and
# are equivalent to the encryption key for every journal/chat row written
# since the last rotation. Never commit them.
keys/
**/keys/key-*.xml
/var/keys/

# ──────────────────────────────────────────────
# Docker local overrides
# ──────────────────────────────────────────────
# docker-compose.override.yml is auto-loaded by `docker compose up` and used
# to leak dev-only DB host ports into production boots. We no longer use it —
# use docker-compose.dev.yml (committed, explicit -f flag) instead. Keep the
# old name ignored so stale copies on developer machines don't re-introduce
# the footgun if they're accidentally recreated.
docker-compose.override.yml

